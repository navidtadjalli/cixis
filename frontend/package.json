{
  "name": "cixis-frontend",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_RUN_AS_NODE= ELECTRON_DEV=1 electron .\"",
    "electron:build": "tsc -b && vite build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@fontsource/vazirmatn": "^5.0.18",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-date-object": "^2.1.9",
    "react-dom": "^18.3.1",
    "react-multi-date-picker": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.2",
    "wait-on": "^7.2.0"
  }
}
