{
  "name": "cixis",
  "private": true,
  "version": "1.1.11",
  "description": "CiXiS — offline-first cafe POS (Electron + React + Django).",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "electron:dev": "npm --prefix frontend run electron:dev",
    "electron:build": "npm --prefix frontend run electron:build",
    "backend": "cd backend && .venv/bin/python manage.py runserver 8000",
    "test:frontend": "npm --prefix frontend test",
    "test:backend": "cd backend && .venv/bin/python manage.py test pos"
  }
}
